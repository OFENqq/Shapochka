@startuml
title Пошаговое взаимодействие в системе "Доставка пирожков"

actor "Шапочка" as H
actor "Бабушка" as G
actor "Волк" as W
actor "Охотник" as Hunter
participant "Корзина" as B

' 1. Шапочка начинает доставку
H -> B ** : взятьПирожки()

' 2. Параллельно: Волк действует быстрее
W -> G : прийтиКДому()
W -> G : съесть()
destroy G
note over G #FFAAAA: Бабушка съедена

' 3. Волк подменяет Бабушку (MITM)
W -> W : маскироваться()

' 4. Шапочка приходит
H -> W : прийтиКДому()

' 5. Проверка личности (диалог)
H -> W : "Почему такие большие зубы?"
W --> H : "Чтобы лучше тебя съесть"

' 6. Развитие событий
W -> H : съесть()

' 7. Спасение
Hunter -> W : разрезатьБрюхо()
Hunter -> G : освободить()
Hunter -> H : освободить()

@enduml
