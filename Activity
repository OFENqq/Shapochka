@startuml
skinparam conditionStyle inside
title Алгоритм системы "Доставка пирожков"

start

:Шапочка: выбрать тропинку;

if (Короткая тропинка?) then (да)
    :Шапочка идет коротким путем;
else (нет)
    :Шапочка идет длинным путем;
endif

fork
    :Шапочка идет к Бабушке;
fork again
    :Волк идет к Бабушке;
    :Волк: съесть Бабушку;
    :Волк: маскироваться;
end fork

:Шапочка приходит к дому;

if (Проверять личность?) then (да)
    :Спросить «Почему такие большие зубы?»;
    :Волк отвечает;

    if (Ответ подозрительный?) then (да)
        :Шапочка понимает обман;
        :Позвать Охотника;
        :Охотник: спасти из брюха;
    else (нет)
        :Передать пирожки;
    endif

else (нет)
    :Передать пирожки;
endif

stop
@enduml
